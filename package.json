{
  "name": "riseact-app-template-node",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "dev": "nodemon --ext .ts --watch ./src/**/* --ignore ./src/frontend/**/* --exec ts-node --project tsconfig.json ./src/index.ts",
    "build": "rm -rf ./build && tsc",
    "start": "NODE_ENV=production node ./build/index.js"
  },
  "dependencies": {
    "@types/express": "^4.17.17",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "riseact-node-sdk": "./riseact-node-sdk-v1.0.0.tgz",
    "serve-static": "^1.15.0"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.9",
    "nodemon": "^2.0.20",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.5"
  }
}
